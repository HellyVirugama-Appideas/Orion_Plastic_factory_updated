        function setStatus(t) { const e = document.getElementById('locationStatus'); if (e) e.textContent = t; }
        function setSpeed(kmh) { const e = document.getElementById('currentSpeed'); if (e) e.textContent = kmh + ' km/h'; }
        function setLastUpdate(t) { const e = document.getElementById('lastUpdate'); if (e) e.textContent = t; }

        function confirmCancel(id) {
            if (!confirm('Cancel this delivery? Driver will be notified.')) return;
            const remarks = prompt('Reason for cancellation:') || 'Cancelled by admin';
            fetch(`/admin/deliveries/${id}/cancel`, {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ remarks })
            })
            .then(r => r.json())
            .then(data => {
                M.toast({ html: data.message || (data.success ? 'Cancelled!' : 'Failed'), classes: data.success ? 'green' : 'red' });
                if (data.success) setTimeout(() => location.reload(), 1500);
            })
            .catch(() => M.toast({ html: 'Network error', classes: 'red' }));
        }

        const _activeStatuses = ['assigned', 'picked_up', 'in_transit', 'In_transit', 'out_for_delivery'];
        if (_activeStatuses.includes(deliveryStatus) && driverId) {
            setInterval(fetchDriverLocation, 30000);
        }
