<!DOCTYPE html>
<html class="loading" lang="en" data-textdirection="ltr">

<head>
    <%- include('_layouts/head') %>
        <title>Create New Order | <%= title %>
        </title>

        <style>
            .btn-gradient {
                background: linear-gradient(45deg, #667eea, #764ba2) !important;
            }

            .item-card {
                background: #fafafa;
                border: 1px solid #e0e0e0;
                border-radius: 8px;
                padding: 20px;
                margin-bottom: 16px;
                position: relative;
            }

            .remove-item-btn {
                position: absolute;
                top: 12px;
                right: 12px;
            }

            .pickup-loc-item {
                background: #f5f5f5;
                border: 1px solid #e0e0e0;
                border-radius: 6px;
                padding: 10px 14px;
                margin-bottom: 8px;
                display: flex;
                align-items: center;
                justify-content: space-between;
                gap: 8px;
            }

            .pickup-loc-item.is-default {
                border-color: #a5d6a7;
                background: #e8f5e9;
            }

            .badge-default {
                background: #43a047;
                color: white;
                font-size: 0.68rem;
                padding: 1px 8px;
                border-radius: 10px;
                font-weight: 600;
                white-space: nowrap;
            }

            .pickup-preview {
                display: none;
                background: #e8f5e9;
                border: 1px solid #a5d6a7;
                border-radius: 8px;
                padding: 12px 16px;
                margin-top: 8px;
                overflow-wrap: break-word;
            }

            .pickup-preview.show {
                display: block;
            }

            .pickup-preview p {
                margin: 3px 0;
                font-size: 0.87rem;
                color: #2e7d32;
            }

            .modal {
                max-height: 92vh !important;
                overflow-y: auto;
            }

            .section-divider {
                border: none;
                border-top: 2px solid #ede7f6;
                margin: 12px 0 18px;
            }

            #addNewPickupForm {
                display: none;
            }

            #addNewPickupForm.show {
                display: block;
            }

            /* ===== MAPS LINK PASTE WIDGET ===== */
            .maps-link-box {
                background: #f3f0ff;
                border: 1px dashed #9c7ee8;
                border-radius: 8px;
                padding: 10px 14px;
                margin-top: 10px;
                display: flex;
                align-items: center;
                gap: 8px;
            }

            .maps-link-box input {
                flex: 1;
                border: none;
                background: transparent;
                font-size: 0.85rem;
                outline: none;
                color: #424242;
                height: 32px;
                box-shadow: none !important;
                margin: 0 !important;
            }

            .maps-link-box .parse-btn {
                background: #667eea;
                color: white;
                border: none;
                border-radius: 6px;
                padding: 4px 12px;
                font-size: 0.8rem;
                cursor: pointer;
                white-space: nowrap;
                flex-shrink: 0;
            }

            .maps-link-box .parse-btn:hover {
                background: #5569d4;
            }

            .maps-link-spinner {
                display: none;
            }

            .maps-link-status {
                font-size: 0.78rem;
                margin-top: 4px;
                padding: 0 2px;
            }

            .maps-link-status.success {
                color: #2e7d32;
            }

            .maps-link-status.error {
                color: #c62828;
            }

            /* Delivery address fields wrapper — highlight when auto-filled */
            .autofill-highlight input,
            .autofill-highlight textarea {
                border-bottom: 2px solid #667eea !important;
                transition: border-color 0.3s;
            }
        </style>
</head>

<body
    class="vertical-layout page-header-light vertical-menu-collapsible vertical-dark-menu preload-transitions 2-columns"
    data-open="click" data-menu="vertical-dark-menu" data-col="2-columns">

    <%- include('_layouts/sidenavbar') %>

        <!-- Hidden: Google Maps API key for front-end geocoding -->
        <script>
            const GMAPS_KEY = '<%= process.env.GOOGLE_MAPS_API_KEY || "" %>';
        </script>

        <div id="main">
            <div class="row">

                <div id="breadcrumbs-wrapper" style="background-color: white;">
                    <div class="container">
                        <div class="row valign-wrapper">
                            <div class="col s12 m6 l6">
                                <h5 class="breadcrumbs-title mb-0"><span>Create New Order</span></h5>
                            </div>
                            <div class="col s12 m6 l6 right-align-md">
                                <a href="/admin/orders"
                                    class="btn gradient-45deg-purple-deep-orange waves-effect waves-light pull-right">
                                    Back to Orders
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <%- include('messages', { messages: messages }) %>

                    <div class="col s12">
                        <div class="container">
                            <div class="card-panel" style="padding:0; border-radius:8px; overflow:hidden;">
                                <div class="card-content" style="padding:30px;">
                                    <form id="createOrderForm" method="POST" action="/admin/orders/create">
                                        <div class="row">

                                            <!-- ===== CUSTOMER ===== -->
                                            <div class="col s12">
                                                <h5 style="color:#424242; font-weight:500; margin-bottom:16px;">
                                                    <i class="material-icons left tiny"
                                                        style="color:#667eea;">person</i>
                                                    Customer Information
                                                </h5>
                                            </div>

                                            <div class="input-field col s12 m8 l6">
                                                <select name="customerId" id="customerId" required>
                                                    <option value="" disabled selected>Select Customer</option>
                                                    <% customers.forEach(c=> { %>
                                                        <option value="<%= c._id %>">
                                                            <%= c.companyName || c.name %> — <%= c.phone %>
                                                        </option>
                                                        <% }) %>
                                                </select>
                                                <label>Customer <span style="color:red">*</span></label>
                                            </div>

                                            <!-- ===== PICKUP LOCATION ===== -->
                                            <div class="col s12" style="margin-top:20px;">
                                                <h5 style="color:#424242; font-weight:500; margin-bottom:16px;">
                                                    <i class="material-icons left tiny" style="color:#667eea;">store</i>
                                                    Pickup Location
                                                </h5>
                                            </div>

                                            <div class="col s12 m8 l6">
                                                <div style="display:flex; align-items:center; gap:10px;">
                                                    <div class="input-field" style="flex:1; margin:0;">
                                                        <select name="pickupLocationId" id="pickupLocationId" required>
                                                            <option value="" disabled selected>-- Select Pickup Location
                                                                --</option>
                                                            <% if (pickupLocations && pickupLocations.length> 0) { %>
                                                                <% pickupLocations.forEach(loc=> { %>
                                                                    <option value="<%= loc._id %>"
                                                                        data-name="<%= loc.name %>"
                                                                        data-address="<%= loc.address %>"
                                                                        data-contact-person="<%= loc.contactPerson || '' %>"
                                                                        data-contact-phone="<%= loc.contactPhone || '' %>"
                                                                        data-default="<%= loc.isDefault ? '1' : '0' %>">
                                                                        <%= loc.name %>
                                                                            <% if(loc.isDefault){ %> (Default)<% } %>
                                                                    </option>
                                                                    <% }) %>
                                                                        <% } %>
                                                        </select>
                                                        <label>Pickup Location <span style="color:red">*</span></label>
                                                    </div>
                                                    <a href="#pickupModal"
                                                        class="modal-trigger btn blue darken-1 waves-effect waves-light"
                                                        style="margin-top:0; white-space:nowrap;">
                                                        <i class="material-icons left">edit_location</i> Manage
                                                    </a>
                                                </div>

                                                <!-- Preview card -->
                                                <div class="pickup-preview" id="pickupPreview">
                                                    <p><strong id="previewName"></strong></p>
                                                    <p><i class="material-icons tiny">location_on</i> <span
                                                            id="previewAddress"></span></p>
                                                    <p id="previewContactRow" style="display:none;">
                                                        <i class="material-icons tiny">person</i> <span
                                                            id="previewContact"></span>
                                                    </p>
                                                    <p id="previewPhoneRow" style="display:none;">
                                                        <i class="material-icons tiny">phone</i> <span
                                                            id="previewPhone"></span>
                                                    </p>
                                                </div>
                                            </div>

                                            <!-- ===== ORDER ITEMS ===== -->
                                            <div class="col s12" style="margin-top:24px;">
                                                <h5 style="color:#424242; font-weight:500; margin-bottom:16px;">
                                                    <i class="material-icons left tiny"
                                                        style="color:#667eea;">inventory_2</i>
                                                    Order Items
                                                </h5>
                                            </div>

                                            <div class="col s12">
                                                <div id="itemsContainer"></div>
                                                <button type="button" onclick="addItem()"
                                                    class="btn btn-gradient waves-effect waves-light mt-2">
                                                    <i class="material-icons left">add_circle_outline</i> Add New Item
                                                </button>
                                            </div>

                                            <!-- ===== DELIVERY INFORMATION ===== -->
                                            <div class="col s12" style="margin-top:24px;">
                                                <h5 style="color:#424242; font-weight:500; margin-bottom:16px;">
                                                    <i class="material-icons left tiny"
                                                        style="color:#667eea;">local_shipping</i>
                                                    Delivery Information
                                                </h5>
                                            </div>

                                            <!-- GOOGLE MAPS LINK PASTE (DELIVERY) -->
                                            <div class="col s12 m8 l7" style="margin-bottom:8px;">
                                                <div class="maps-link-box">
                                                    <i class="material-icons"
                                                        style="color:#667eea; font-size:20px;">location_on</i>
                                                    <input type="text" id="deliveryMapsLink"
                                                        placeholder="Paste Google Maps link to auto-fill delivery address…"
                                                        onkeydown="if(event.key==='Enter'){event.preventDefault();parseDeliveryLink();}">
                                                    <button type="button" class="parse-btn"
                                                        onclick="parseDeliveryLink()">
                                                        <i class="material-icons tiny">my_location</i> Fill
                                                    </button>
                                                </div>
                                                <div class="maps-link-status" id="deliveryLinkStatus"></div>
                                            </div>

                                            <!-- Hidden lat/lng for delivery -->
                                            <input type="hidden" name="deliveryLocation[coordinates][latitude]"
                                                id="delLat">
                                            <input type="hidden" name="deliveryLocation[coordinates][longitude]"
                                                id="delLng">

                                            <div id="deliveryFields">
                                                <div class="input-field col s12 m6">
                                                    <input id="contactPerson" name="deliveryLocation[contactPerson]"
                                                        type="text" required>
                                                    <label for="contactPerson">Contact Person <span
                                                            style="color:red">*</span></label>
                                                </div>
                                                <div class="input-field col s12 m6">
                                                    <input id="contactPhone" name="deliveryLocation[contactPhone]"
                                                        type="tel" value="+971 " pattern="^\+971\s?5[0-9]{8}$"
                                                        maxlength="14" required>
                                                    <label for="contactPhone">Contact Phone (+971) <span
                                                            style="color:red">*</span></label>
                                                    <span class="helper-text"
                                                        data-error="Enter valid UAE number (e.g. +971 5XXXXXXXX)"></span>
                                                </div>
                                                <div class="input-field col s12">
                                                    <textarea id="delAddress" name="deliveryLocation[address]"
                                                        class="materialize-textarea" required></textarea>
                                                    <label for="delAddress">Full Delivery Address <span
                                                            style="color:red">*</span></label>
                                                </div>
                                                <div class="input-field col s12 m4">
                                                    <input id="city" name="deliveryLocation[city]" type="text" required>
                                                    <label for="city">City <span style="color:red">*</span></label>
                                                </div>
                                                <div class="input-field col s12 m4">
                                                    <input id="state" name="deliveryLocation[state]" type="text"
                                                        required>
                                                    <label for="state">State <span style="color:red">*</span></label>
                                                </div>
                                                <div class="input-field col s12 m4">
                                                    <input id="pincode" name="deliveryLocation[pincode]" type="text"
                                                        maxlength="12" required>
                                                    <label for="pincode">Pincode / ZIP <span
                                                            style="color:red">*</span></label>
                                                </div>
                                            </div>

                                            <!-- ===== ORDER DETAILS ===== -->
                                            <div class="col s12" style="margin-top:16px;">
                                                <h5 style="color:#424242; font-weight:500; margin-bottom:16px;">
                                                    <i class="material-icons left tiny" style="color:#667eea;">tune</i>
                                                    Order Details
                                                </h5>
                                            </div>

                                            <div class="input-field col s12 m6">
                                                <select name="orderType">
                                                    <option value="retail" selected>Retail</option>
                                                    <option value="wholesale">Wholesale</option>
                                                    <option value="bulk">Bulk</option>
                                                    <option value="custom">Custom</option>
                                                </select>
                                                <label>Order Type</label>
                                            </div>
                                            <div class="input-field col s12 m6">
                                                <select name="priority">
                                                    <option value="low">Low</option>
                                                    <option value="medium" selected>Medium</option>
                                                    <option value="high">High</option>
                                                    <option value="urgent">Urgent</option>
                                                </select>
                                                <label>Priority</label>
                                            </div>

                                            <!-- ===== SPECIAL INSTRUCTIONS ===== -->
                                            <div class="col s12" style="margin-top:16px;">
                                                <h5 style="color:#424242; font-weight:500; margin-bottom:16px;">
                                                    <i class="material-icons left tiny" style="color:#667eea;">note</i>
                                                    Special Instructions
                                                </h5>
                                            </div>
                                            <div class="input-field col s12">
                                                <textarea name="specialInstructions"
                                                    class="materialize-textarea"></textarea>
                                                <label>Special Instructions (Optional)</label>
                                            </div>
                                            <div class="input-field col s12">
                                                <textarea name="packagingInstructions"
                                                    class="materialize-textarea"></textarea>
                                                <label>Packaging Instructions (Optional)</label>
                                            </div>

                                            <input type="hidden" name="items" id="itemsJSON">

                                            <!-- Submit -->
                                            <div class="col s12 right-align" style="margin-top:24px;">
                                                <a href="/admin/orders" class="btn grey waves-effect waves-light"
                                                    style="margin-right:10px;">Cancel</a>
                                                <button type="submit" class="btn btn-gradient waves-effect waves-light">
                                                    <i class="material-icons left">check_circle</i> Create Order
                                                </button>
                                            </div>

                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </div>
            </div>
        </div>

        <!-- ================================================================
         PICKUP LOCATION MODAL
    ================================================================ -->
        <div id="pickupModal" class="modal" style="width:620px; max-width:95vw;">
            <div class="modal-content">
                <h5 style="font-weight:600; color:#424242; margin-bottom:4px;">
                    <i class="material-icons left" style="color:#667eea;">location_on</i>
                    Manage Pickup Locations
                </h5>
                <hr class="section-divider">

                <div id="pickupLocList"></div>

                <!-- GOOGLE MAPS LINK PASTE (inside modal) -->
                <div class="maps-link-box" style="margin-bottom:12px;">
                    <i class="material-icons" style="color:#667eea; font-size:20px;">location_on</i>
                    <input type="text" id="modalMapsLink"
                        placeholder="Paste Google Maps link to auto-fill below fields…"
                        onkeydown="if(event.key==='Enter'){event.preventDefault();parseModalLink();}">
                    <button type="button" class="parse-btn" onclick="parseModalLink()">
                        <i class="material-icons tiny">my_location</i> Fill
                    </button>
                </div>
                <div class="maps-link-status" id="modalLinkStatus"></div>

                <button type="button" id="toggleAddBtn" onclick="toggleAddForm()"
                    class="btn btn-gradient waves-effect waves-light" style="margin-bottom:16px;">
                    <i class="material-icons left">add</i> Add New Location
                </button>

                <!-- Add New Location Form -->
                <div id="addNewPickupForm">
                    <hr class="section-divider">
                    <p style="font-weight:600; color:#424242; margin-bottom:12px;">New Pickup Location</p>
                    <div class="row" style="margin-bottom:0;">
                        <div class="input-field col s12 m6">
                            <input type="text" id="n_name">
                            <label for="n_name">Location Name <span style="color:red">*</span></label>
                        </div>
                        <div class="input-field col s12 m6">
                            <input type="text" id="n_contactPerson">
                            <label for="n_contactPerson">Contact Person</label>
                        </div>
                        <div class="input-field col s12">
                            <textarea id="n_address" class="materialize-textarea"></textarea>
                            <label for="n_address">Full Address <span style="color:red">*</span></label>
                        </div>
                        <div class="input-field col s12 m4">
                            <input type="text" id="n_city">
                            <label for="n_city">City</label>
                        </div>
                        <div class="input-field col s12 m4">
                            <input type="text" id="n_state">
                            <label for="n_state">State</label>
                        </div>
                        <div class="input-field col s12 m4">
                            <input type="text" id="n_pincode" maxlength="12">
                            <label for="n_pincode">Pincode</label>
                        </div>
                        <div class="input-field col s12 m6">
                            <input type="text" id="n_contactPhone">
                            <label for="n_contactPhone">Contact Phone</label>
                        </div>
                        <div class="input-field col s12 m3">
                            <input type="number" id="n_lat" step="any">
                            <label for="n_lat">Latitude <span style="color:red">*</span></label>
                        </div>
                        <div class="input-field col s12 m3">
                            <input type="number" id="n_lng" step="any">
                            <label for="n_lng">Longitude <span style="color:red">*</span></label>
                        </div>
                        <div class="col s12" style="margin-bottom:12px;">
                            <label>
                                <input type="checkbox" id="n_isDefault" class="filled-in">
                                <span>Set as Default</span>
                            </label>
                        </div>
                        <div class="col s12">
                            <button type="button" onclick="saveNewPickup()"
                                class="btn btn-gradient waves-effect waves-light">
                                <i class="material-icons left">save</i> Save Location
                            </button>
                            <button type="button" onclick="toggleAddForm()" class="btn grey waves-effect waves-light"
                                style="margin-left:8px;">
                                Cancel
                            </button>
